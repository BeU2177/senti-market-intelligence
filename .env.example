# Senti Market Intelligence — Production Configuration Template

# Market & News Provider Settings
DEFAULT_SYMBOL=AAPL
MARKET_DATA_PROVIDER=yfinance
NEWS_API_KEY=your_news_api_key_here

# Local LLM & Prompt Settings
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Vector DB & Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB_PATH=artifacts/vector_db

# Application & Logging Controls
APP_NAME=Senti Market Intelligence
LOG_LEVEL=INFO
PORT=8000
MAX_ALLOWED_FRESHNESS_SEC=300
